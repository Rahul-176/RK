class Solution {
  public:
    string triDownwards(string S) {
        // code here
        int n = S.length();
        
        string R ="";
        for(int i=0; i<n; i++ )
        
        {
            
            
            for(int j=0;j<i;++j)
            {
                S[j]='.';
            }
            cout<<S<<endl;
            
        }
        
        return R ;
    }
};

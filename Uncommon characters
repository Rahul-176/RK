#include<vector>

class Solution {
  public:
    string uncommonChars(string& s1, string& s2) {
        // code here
        
        vector<int> freq1(26,0);
        vector<int> freq2(26,0);
        
        for(char s : s1)
        {
            freq1[s-'a']++;
            
        }
        
        
        for(char r :s2)
        {
            freq2[r- 'a']++;
        }
        
        
        string result="";
        
        for(int i=0; i< 26; i++)
        {
            if((freq1[i]>0 && freq2[i]==0)  ||( freq2[i]>0 && freq1[i]==0) )
            {
               result += ( i +'a'); 
            }
            
        }
        
        return result;
    }
    
};
